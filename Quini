<script>
    async function razonar() {
        const display = document.getElementById('display');
        display.innerHTML = "PROCESANDO_DATOS...";

        try {
            // Buscamos los datos reales del JSON que creamos
            const response = await fetch('data.json');
            const data = await response.json();
            const hot = data.ultimos_3_anos.mas_frecuentes;

            let sugerencia = [];
            
            // Lógica de razonamiento: 
            // 1. Elegimos 4 números de alta frecuencia (Hot)
            // 2. Elegimos 2 números al azar para evitar patrones fijos
            while(sugerencia.length < 4) {
                let n = hot[Math.floor(Math.random() * hot.length)];
                if(!sugerencia.includes(n)) sugerencia.push(n);
            }
            while(sugerencia.length < 6) {
                let n = Math.floor(Math.random() * 46);
                if(!sugerencia.includes(n)) sugerencia.push(n);
            }

            sugerencia.sort((a, b) => a - b);

            // Dibujamos las bolas en pantalla
            display.innerHTML = '';
            sugerencia.forEach(num => {
                display.innerHTML += `<div class="bola">${num < 10 ? '0'+num : num}</div>`;
            });

        } catch (error) {
            display.innerHTML = "ERROR_AL_LEER_DATA";
            console.error(error);
        }
    }
</script>
